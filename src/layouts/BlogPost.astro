---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';

interface Props {
    entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, date, author: authorRef, description, cover_image, tags } = entry.data;
const author = await getEntry(authorRef);
const { Content } = await entry.render();

const formattedDate = new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});
---

<BaseLayout title={`${title} - Shoelace Studios Blog`} description={description}>
    <article class="blog-post">
        <header class="post-header">
            <div class="post-header-content">
                {tags && tags.length > 0 && (
                        <div class="tags">
                            {tags.map(tag => (
                                    <span class="tag">{tag}</span>
                            ))}
                        </div>
                )}
                <h1>{title}</h1>
                <p class="description">{description}</p>
                <div class="meta">
                    <div class="author">
                        <img
                                src={author.data.avatar}
                                alt={author.data.name}
                                class="author-avatar"
                        />
                        <span class="author-name">{author.data.name}</span>
                    </div>
                    <time datetime={date.toISOString()}>{formattedDate}</time>
                </div>
            </div>
        </header>

        {cover_image && (
                <figure class="cover-image-container">
                    <img
                            src={cover_image}
                            alt={`Cover image for ${title}`}
                            class="cover-image"
                    />
                </figure>
        )}

        <div class="content">
            <Content/>
        </div>

        <footer class="post-footer">
            <div class="author-bio">
                <img
                        src={author.data.avatar}
                        alt={author.data.name}
                        class="author-avatar-large"
                />
                <div class="author-info">
                    <h3>Written by {author.data.name}</h3>
                    <p>{author.data.bio}</p>
                </div>
            </div>
        </footer>
    </article>
</BaseLayout>

<style>
    .blog-post {
        max-width: 65rem;
        margin: 0 auto;
        padding: 6rem 1rem 2rem;
    }

    .post-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .post-header-content {
        max-width: 48rem;
        margin: 0 auto;
    }

    .tags {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .tag {
        background-color: rgba(245, 100, 32, 0.2);
        color: var(--color-accent);
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.5rem);
        color: white;
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .description {
        color: rgb(209, 213, 219);
        font-size: 1.25rem;
        margin-bottom: 1.5rem;
        line-height: 1.5;
    }

    .meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        color: rgb(209, 213, 219);
        flex-wrap: wrap;
    }

    .author {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .author-avatar {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        object-fit: cover;
    }

    .cover-image-container {
        margin: 2rem 0;
    }

    .cover-image {
        width: 100%;
        max-height: 24rem;
        object-fit: cover;
        border-radius: 0.5rem;
    }

    .content {
        max-width: 48rem;
        margin: 0 auto;
        color: rgb(209, 213, 219);
    }

    .content :global(h2) {
        color: var(--color-accent);
        font-size: 1.875rem;
        margin: 2rem 0 1rem;
    }

    .content :global(h3) {
        color: white;
        font-size: 1.5rem;
        margin: 1.5rem 0 1rem;
    }

    .content :global(p) {
        margin-bottom: 1.5rem;
        line-height: 1.8;
    }

    .content :global(a) {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .content :global(a:hover) {
        color: rgb(255, 130, 62);
        text-decoration: underline;
    }

    .content :global(ul),
    .content :global(ol) {
        color: rgb(209, 213, 219);
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
        line-height: 1.8;
    }

    .content :global(ul) {
        list-style: disc;
    }

    .content :global(ol) {
        list-style: decimal;
    }

    .content :global(code) {
        background-color: rgba(255, 255, 255, 0.1);
        padding: 0.2rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.9em;
    }

    .content :global(pre) {
        background-color: rgba(22, 34, 42, 0.95);
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin: 1.5rem 0;
    }

    .content :global(pre code) {
        background: none;
        padding: 0;
    }

    .content :global(img) {
        max-width: 100%;
        border-radius: 0.5rem;
        margin: 1.5rem 0;
    }

    .content :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        margin: 1.5rem 0;
        padding: 0.5rem 0 0.5rem 1.5rem;
        color: rgb(209, 213, 219);
        font-style: italic;
    }

    .post-footer {
        max-width: 48rem;
        margin: 4rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .author-bio {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .author-avatar-large {
        width: 4rem;
        height: 4rem;
        border-radius: 9999px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .author-info h3 {
        color: white;
        margin-bottom: 0.5rem;
    }

    .author-info p {
        color: rgb(209, 213, 219);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    @media (max-width: 768px) {
        .meta {
            flex-direction: column;
            gap: 1rem;
        }

        .author-bio {
            flex-direction: column;
            text-align: center;
        }
    }
</style>