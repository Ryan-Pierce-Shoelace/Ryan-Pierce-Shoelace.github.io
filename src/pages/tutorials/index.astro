---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {getCollection} from 'astro:content';

const tutorials = await getCollection('tutorials');

const sortedTutorials = [...tutorials].sort((a, b) =>
    b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Tutorials - Shoelace Studios" description="Learn game development with our step-by-step guides">
    <main class="site-content">
        <div class="content-wrapper">
            <header class="page-header">
                <h1>Tutorials</h1>
                <p class="subtitle">Learn game development with our step-by-step guides</p>
            </header>

            <div class="tutorials-grid">
                {sortedTutorials.map((tutorial) => (
                        <a href={`/tutorials/${tutorial.slug}`} class="tutorial-card">
                            <div class="thumbnail-container">
                                {tutorial.data.thumbnail ? (
                                        <img
                                                src={tutorial.data.thumbnail}
                                                alt={`Thumbnail for ${tutorial.data.title}`}
                                                width="640"
                                                height="360"
                                                class="thumbnail"
                                        />
                                ) : (
                                        <div class="thumbnail-placeholder">
                                            <span>No Thumbnail</span>
                                        </div>
                                )}
                                <div class="indicators">
                                    {tutorial.data.type === 'video' && (
                                            <div class="type-indicator">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                     fill="currentColor" class="video-icon">
                                                    <path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 000-1.69L9.54 5.98A.998.998 0 008 6.82z"/>
                                                </svg>
                                                Video
                                            </div>
                                    )}
                                    <div class="difficulty" data-level={tutorial.data.difficulty.toLowerCase()}>
                                        {tutorial.data.difficulty}
                                    </div>
                                </div>
                            </div>
                            <div class="tutorial-info">
                                <h2>{tutorial.data.title}</h2>
                                <p>{tutorial.data.description}</p>
                                <div class="meta">
                                    <span class="time">{tutorial.data.estimated_time} min</span>
                                    <span class="date">
                                    {new Date(tutorial.data.date).toLocaleDateString('en-US', {
                                        year: 'numeric',
                                        month: 'short',
                                        day: 'numeric'
                                    })}
                                </span>
                                </div>
                            </div>
                        </a>
                ))}
            </div>
        </div>
    </main>
</BaseLayout>

<style>
    .site-content {
        min-height: calc(100vh - 60px);
        padding-top: 5rem;
        padding-bottom: 2rem;
    }

    .content-wrapper {
        max-width: 85rem;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-top: 1rem;
    }

    .page-header h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        color: white;
        margin-bottom: 1rem;
    }

    .subtitle {
        color: rgb(209, 213, 219);
        font-size: 1.25rem;
    }

    .tutorials-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .tutorial-card {
        background-color: rgba(22, 34, 42, 0.95);
        border-radius: 0.5rem;
        overflow: hidden;
        transition: transform 0.3s ease;
        text-decoration: none;
    }

    .tutorial-card:hover {
        transform: translateY(-4px);
    }

    .thumbnail-container {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        background-color: rgba(0, 0, 0, 0.2);
        overflow: hidden;
    }

    .thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .thumbnail-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(22, 34, 42, 0.95);
        color: rgb(209, 213, 219);
        font-size: 0.875rem;
    }

    .indicators {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        display: flex;
        gap: 0.5rem;
    }

    .type-indicator {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        background-color: rgba(59, 130, 246, 0.9);
        color: white;
    }

    .video-icon {
        width: 1rem;
        height: 1rem;
    }

    .difficulty {
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .difficulty[data-level="beginner"] {
        background-color: rgba(34, 197, 94, 0.9);
        color: white;
    }

    .difficulty[data-level="intermediate"] {
        background-color: rgba(245, 158, 11, 0.9);
        color: white;
    }

    .difficulty[data-level="advanced"] {
        background-color: rgba(239, 68, 68, 0.9);
        color: white;
    }

    .tutorial-info {
        padding: 1.5rem;
    }

    .tutorial-info h2 {
        font-size: 1.25rem;
        color: white;
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .tutorial-info p {
        color: rgb(209, 213, 219);
        font-size: 0.875rem;
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .meta {
        display: flex;
        gap: 1rem;
        font-size: 0.875rem;
        color: rgb(156, 163, 175);
    }

    @media (min-width: 640px) {
        .tutorials-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .tutorials-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>